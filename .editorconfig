# EditorConfig — editors and tools use this to stay in sync with Spotless
# https://editorconfig.org

root = true

[*]
charset             = utf-8
end_of_line         = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.java]
indent_style = space
indent_size  = 4
max_line_length = 160

[*.gradle]
indent_style = space
indent_size  = 4

[*.{yml,yaml}]
indent_style = space
indent_size  = 2

[*.{json,md}]
indent_style = space
indent_size  = 2

[*.xml]
indent_style = space
indent_size  = 4
